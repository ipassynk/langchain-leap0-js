{
  "name": "@leap0/langchain-leap0",
  "version": "0.1.0",
  "description": "Leap0 sandbox backend for deepagents (TypeScript)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist/ .tsdown/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:int": "vitest run --mode int",
    "example:basic": "tsx examples/basic_sandbox.ts",
    "example:deep-agent": "tsx examples/deep_agent_sandbox.ts"
  },
  "keywords": [
    "ai",
    "agents",
    "langchain",
    "langgraph",
    "leap0",
    "sandbox",
    "deepagents"
  ],
  "license": "Apache-2.0",
  "dependencies": {},
  "peerDependencies": {
    "deepagents": ">=1.9.0",
    "leap0": ">=0.3.0"
  },
  "devDependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.1",
    "@langchain/sandbox-standard-tests": "^1.0.0",
    "@tsconfig/recommended": "^1.0.13",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "deepagents": "^1.9.0",
    "dotenv": "^17.2.3",
    "leap0": "^0.3.1",
    "tsdown": "^0.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*"
  ],
  "engines": {
    "node": ">=20.6.0"
  },
  "packageManager": "pnpm@10.18.3"
}
